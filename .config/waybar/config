{
    "layer": "top", // Waybar at top layer
    "position": "left", // Waybar position (top|bottom|left|right)
    "width": 10,
    "spacing": 2, // Gaps between modules (4px)
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": [
      "custom/recorder-state",
      "custom/vpn",
      "custom/pacman",
      "cpu",
      "memory",
      "pulseaudio",
      "backlight",
      "battery",
      "clock",
      "custom/audio_idle_inhibitor",
      "idle_inhibitor"
    ],

    // Modules configuration
    "sway/workspaces": {
        "all-outputs": true,
        "disable-scroll": true,
        "format": "{index}{icon}",
        "format-icons": { "urgent": ":пҒӘ", "focused": "", "default": "", "persistent": "P" }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>",
        "rotate": 90
    },
    "sway/window": {
        "rotate": 90
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ®",
            "deactivated": "пҒ°"
        }
    },
    "custom/audio_idle_inhibitor": {
        "format": "{icon}",
        "exec": "sway-audio-idle-inhibit --dry-print-both-waybar",
        "exec-if": "which sway-audio-idle-inhibit",
        "return-type": "json",
        "format-icons": {
            "output": "",
            "input": "п„°",
            "output-input": "п…„\nп„°",
            "none": "рҹ”Ү"
        }
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "<small>{:%b</small>\n%d\n%H\n%M}",
        "format-alt": "{:%Y-%m-%d(%a) %H:%M}"
    },
    "cpu": {
        "format": "<big>пӢӣ</big>\n{usage:2}\n{load:2.0f}",
        "tooltip": true,
    },
    "memory": {
        "format": "<big>пғү</big>\n{used:2.0f}",
        "format-alt": "<big>пғү</big>\n{used:0.1f}G\n{total:0.1f}G\n({percentage}%)"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "<big>{icon}</big>\n{percent}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"],
        "on-click": "backlight_control +10",
        "on-click-right": "backlight_control -10"
    },
    "battery": {
        "states": {
            "full": 100,
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "<big>{icon}</big>\n{capacity}",
        "format-charging": "п—§\n{capacity}",
        "format-plugged": "пҮҰ\n{capacity}",
        "format-plugged": "",
        "format-alt": "{time} {icon}",
        "format-good": "", // An empty format will hide the module
        "format-full": "",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "<big>{icon}</big>\n{volume:2}\n{format_source}",
        "format-bluetooth": "<big>пҠ”</big>\n{icon}\n{volume}%\n{format_source}",
        "format-bluetooth-muted": "<big>пҠ”</big>\n<big>рҹ”Ү</big>\n{format_source}",
        "format-muted": "<big>рҹ”Ү</big>\n{format_source}",
        "format-source": "<big>п„°</big>\n{volume}",
        "format-source-muted": "п„ұ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "п–җ",
            "headset": "п–җ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖ§", "пҖЁ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/recorder-state": {
        "format": "<big>вҸәпёҸ</big>",
        "interval": 5,
        "exec": "$XDG_CONFIG_HOME/waybar/scripts/recorder-state.sh",
        "exec-if": "exit 0"
     },
    "custom/vpn": {
        "format": "<big>пӮ¬</big>",
        "interval": 5,
        "exec": "$XDG_CONFIG_HOME/waybar/scripts/vpn.sh",
        "exec-if": "exit 0"
     },
    "custom/pacman": {
        "format": "<big>пҢғ</big>\n{}",
        "interval": 3600,
        "exec": "checkupdates | wc -l | sed -E 's/^0$//g'",
        "exec-if": "exit 0",
        "signal": 8,
        "min-length": 4
    },
}
